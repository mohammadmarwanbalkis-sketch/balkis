{
  "name": "@balkis/decimal",
  "version": "0.1.0",
  "description": "Exact decimal arithmetic for the Balkis framework: bigint-backed fixed-point numbers with explicit rounding modes (banker's rounding by default). Decimals travel through calculations as plain strings — JSON-safe, schema-validated, no float drift.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@balkis/core": "workspace:^",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "decimal",
    "money",
    "bigint",
    "fixed-point",
    "bankers-rounding",
    "currency",
    "typescript"
  ]
}
