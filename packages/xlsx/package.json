{
  "name": "@balkis/xlsx",
  "version": "0.1.0",
  "description": "Import Excel workbooks into Balkis calculations: formulas become typed, auditable calculation definitions with dependencies inferred from cell references — plus an honest coverage report for everything that could not be translated. Zero dependencies.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "@balkis/core": "workspace:^",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "excel",
    "xlsx",
    "spreadsheet",
    "migration",
    "formulas",
    "import",
    "typescript"
  ]
}
