{
  "name": "@balkis/rules",
  "version": "0.1.0",
  "description": "Declarative rule engine for the Balkis framework. Rules are JSON-serializable condition trees with priorities and evaluation strategies; rule groups compile into ordinary Balkis calculations.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "@balkis/core": "workspace:^",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "rules-engine",
    "business-rules",
    "conditions",
    "decision-table",
    "typescript"
  ]
}
