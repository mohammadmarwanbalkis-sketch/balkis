{
  "name": "@balkis/versioning",
  "version": "0.1.0",
  "description": "Safe evolution of Balkis calculation catalogs: semantic catalog diffs with breaking-change detection, and shadow runs that execute a candidate catalog against real inputs alongside the current one before you switch.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "@balkis/core": "workspace:^",
    "@balkis/scenarios": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0",
    "zod": "^4.0.0"
  },
  "keywords": [
    "versioning",
    "shadow-deployment",
    "breaking-changes",
    "diff",
    "migration",
    "typescript"
  ]
}
